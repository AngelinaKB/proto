OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.0

DB1_HOST=your-host
DB1_PORT=5432
DB1_NAME=wm_etl
DB1_USER=
DB1_PASSWORD=
DB1_TABLES=wm_etl.dbo.customreportlog

DB2_HOST=your-host
DB2_PORT=5432
DB2_NAME=webmethoddb
DB2_USER=
DB2_PASSWORD=
DB2_TABLES=webmethoddb.wmutil.flowserviceinformation

APP_MAX_SQL_LIMIT=500
APP_DEFAULT_SQL_LIMIT=100
APP_SHOW_SQL=true
APP_MAX_QUERY_LENGTH=1000

# Comma-separated fully-qualified table names
APP_ALLOWED_TABLES=

# Column schema 
APP_TABLE_COLUMNS=

# CORS
APP_CORS_ORIGINS=*
APP_CORS_METHODS=*
APP_CORS_HEADERS=*

# DB connection pool
APP_DB_POOL_MIN=1
APP_DB_POOL_MAX=10


