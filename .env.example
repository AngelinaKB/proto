OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.0

POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

APP_MAX_SQL_LIMIT=500
APP_DEFAULT_SQL_LIMIT=100
APP_SHOW_SQL=true
APP_MAX_QUERY_LENGTH=1000

# Comma-separated fully-qualified table names
APP_ALLOWED_TABLES=

# Column schema 
APP_TABLE_COLUMNS=

# CORS
APP_CORS_ORIGINS=*
APP_CORS_METHODS=*
APP_CORS_HEADERS=*

# DB connection pool
APP_DB_POOL_MIN=1
APP_DB_POOL_MAX=10


# Columns stored as varchar that need casting to timestamp for time comparisons
# Format: table:col1,col2|table:col1,col2
APP_TIMESTAMP_CAST_COLUMNS=wm_etl.dbo.customreportlog:logtime|webmethoddb.wmutil.flowserviceinformation:scheduledateutc,lastrunutc,updatedate
